import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt


df_sample = df.sample(n=100000, random_state=42)
sns.set_theme(style="whitegrid")

fig, axes = plt.subplots(3, 2, figsize=(16, 18))

# 1. Histogram: Birth Year
sns.histplot(df_sample['birth_year'], bins=30, kde=True, ax=axes[0,0], color='skyblue')
axes[0,0].set_title('Distribution of Patient Birth Years')

# 2. Box Plot: Severity by Sex
sns.boxplot(x='sex', y='severity_index', data=df_sample, ax=axes[0,1], palette='Set2')
axes[0,1].set_title('Clinical Severity Index by Gender')

# 3. Bar Chart: Comorbidity Count
sns.countplot(x='comorbidity_count', data=df_sample, ax=axes[1,0], palette='viridis')
axes[1,0].set_title('Frequency of Comorbidity Counts')

# 4. Pie Chart: Diabetes Prevalence
diabetes_counts = df_sample['has_diabetes'].value_counts()
axes[1,1].pie(diabetes_counts, labels=['No Diabetes', 'Diabetes'], autopct='%1.1f%%', colors=['lightgrey', 'orange'])
axes[1,1].set_title('Prevalence of Diabetes')

# 5. Heatmap: Vitals Correlation
vitals = ['sbp_mmhg', 'dbp_mmhg', 'heart_rate_bpm', 'spo2_pct', 'bmi']
sns.heatmap(df_sample[vitals].corr(), annot=True, cmap='coolwarm', ax=axes[2,0])
axes[2,0].set_title('Clinical Vitals Correlation Matrix')

axes[2,1].axis('off') 
plt.tight_layout()
plt.show()

fig, axes = plt.subplots(3, 2, figsize=(16, 18))

# 1. Histogram: Length of Stay
sns.histplot(df_sample['los_days'], bins=20, ax=axes[0,0], color='salmon')
axes[0,0].set_title('Distribution of Length of Stay (Days)')

# 2. Bar Chart: Volume by Unit
sns.countplot(y='unit_assigned', data=df_sample, ax=axes[0,1], order=df_sample['unit_assigned'].value_counts().index)
