import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Sampling for performance
df_sample = df.sample(n=100000, random_state=42)
df_sample['admit_timestamp'] = pd.to_datetime(df_sample['admit_timestamp'])

# 1. Line Chart: Admission Trends by Generation
# Grouping birth years into decades to make the line chart readable
df_sample['birth_decade'] = (df_sample['birth_year'] // 10) * 10
timeline = df_sample.groupby([df_sample['admit_timestamp'].dt.to_period('M'), 'birth_decade']).size().unstack()

plt.figure(figsize=(14, 6))
timeline.plot(kind='line', ax=plt.gca(), marker='o')
plt.title('Monthly Admission Trends by Patient Birth Decade')
plt.ylabel('Number of Encounters')
plt.xlabel('Time (Monthly)')
plt.legend(title='Birth Year Decade', bbox_to_anchor=(1.05, 1), loc='upper left')
plt.grid(True)
plt.show()

